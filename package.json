{
  "name": "scriptnotebook",
  "displayName": "Terminal Notebook for Markdown",
  "publisher": "awsxxf",
  "version": "0.0.8",
  "description": "%description%",
  "extensionKind": [
    "ui"
  ],
  "engines": {
    "vscode": "^1.76.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/littrick/vscode-serial-terminal.git"
  },
  "homepage": "https://github.com/littrick/vscode-serial-terminal/blob/main/scriptNoteBook/README.md",
  "bugs": {
    "url": "https://github.com/littrick/vscode-serial-terminal/issues"
  },
  "keywords": [
    "script notebook",
    "terminal notebook"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "notebooks": [
      {
        "type": "scrnb",
        "displayName": "%notebooks.scrnb.displayName%",
        "selector": [
          {
            "filenamePattern": "*.scrnb"
          }
        ]
      },
      {
        "type": "mdnb",
        "displayName": "%notebooks.mdnb.displayName%",
        "selector": [
          {
            "filenamePattern": "*.mdnb"
          },
          {
            "filenamePattern": "*.md"
          }
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname =~ /\\.md|\\.mdnb/ && activeEditor == 'workbench.editors.files.textFileEditor'",
          "command": "scriptNotebook.openWithNotebook",
          "group": "navigation"
        },
        {
          "when": "resourceExtname =~ /\\.md|\\.mdnb/ && activeEditor == 'workbench.editor.notebook'",
          "command": "scriptNotebook.openWithMarkdown",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "scriptNotebook.openWithNotebook",
        "title": "%commands.scriptNotebook.openWithNotebook.title%",
        "icon": "$(notebook)"
      },
      {
        "command": "scriptNotebook.openWithMarkdown",
        "title": "%commands.scriptNotebook.openWithMarkdown.title%",
        "icon": "$(notebook)"
      }
    ],
    "configuration": [
      {
        "title": "%configuration.title%",
        "properties": {
          "scriptNotebook.code.supports": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "sh",
              "txt",
              "shellscript",
              "plaintext",
              ""
            ],
            "markdownDescription": "%configuration.code.supports.markdownDescription%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.18.126",
    "@types/vscode": "1.76.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vscode/l10n-dev": "^0.0.26",
    "@vscode/test-electron": "^2.5.2",
    "electron": "^25.9.8",
    "eslint": "^8.57.1",
    "glob": "^8.1.0",
    "mocha": "^10.8.2",
    "typescript": "^5.9.3"
  }
}
