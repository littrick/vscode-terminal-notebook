{
  "name": "terminalnotebook",
  "displayName": "TerminalNoteBook",
  "description": "",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalnotebook.helloWorld",
        "title": "Hello World"
      }
    ],
    "notebooks": [
      {
        "type": "TerminalNoteBook",
        "displayName": "TerminalNoteBook",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ]
      }
    ],
    "configuration": [
      {
        "title": "Terminal Notebook",
        "properties": {
          "TerminalNoteBook.LanguageId Surported": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "shellscript",
              "sh",
              "raw",
              "plaintext",
              ""
            ],
            "markdownDescription": ""
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@types/vscode": "^1.70.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.9.1",
    "typescript": "^5.5.4"
  }
}