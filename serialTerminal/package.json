{
  "name": "serialterminal",
  "displayName": "serial terminal",
  "publisher": "awsxxf",
  "version": "0.0.36",
  "description": "An interactive serial terminal tool",
  "extensionKind": [
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AWSXXF/vscode-serial-terminal.git"
  },
  "homepage": "https://github.com/AWSXXF/vscode-serial-terminal/blob/main/serialTerminal/README.md",
  "bugs": {
    "url": "https://github.com/AWSXXF/vscode-serial-terminal/issues"
  },
  "icon": "./assets/logo.png",
  "l10n": "./l10n",
  "keywords": [
    "serial port",
    "serial",
    "com",
    "terminal",
    "console",
    "uart"
  ],
  "pricing": "Free",
  "engines": {
    "vscode": "^1.76.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "extensionPack": [
    "awsxxf.scriptnotebook"
  ],
  "extensionDependencies": [
    "awsxxf.scriptnotebook"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "entryView",
          "title": "%entryView.title%",
          "icon": "$(debug-disconnect)"
        }
      ]
    },
    "views": {
      "entryView": [
        {
          "name": "%TreeView.serialPorts%",
          "id": "serialport.serialportView",
          "initialSize": 20
        },
        {
          "name": "%TreeView.logs%",
          "id": "serialport.logs",
          "initialSize": 50
        },
        {
          "name": "%TreeView.scriptsNotebooks%",
          "id": "serialport.scriptsNotebooks",
          "initialSize": 20
        }
      ]
    },
    "terminal": {
      "profiles": [
        {
          "id": "serialPortTerminal",
          "title": "%serialPortTerminal%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "serialTerminal.serialView.refresh",
          "when": "view == serialport.serialportView",
          "group": "navigation@2"
        },
        {
          "command": "serialTerminal.setting.SerialPort",
          "when": "view == serialport.serialportView",
          "group": "navigation@1"
        },
        {
          "command": "serialTerminal.setting.Log",
          "when": "view == serialport.logs",
          "group": "navigation@1"
        },
        {
          "command": "serialTerminal.logView.revealLogs",
          "when": "view == serialport.logs",
          "group": "navigation@2"
        },
        {
          "command": "serialTerminal.scriptView.newNotebook",
          "when": "view == serialport.scriptsNotebooks",
          "group": "navigation@1"
        },
        {
          "command": "serialTerminal.setting.Notebook",
          "when": "view == serialport.scriptsNotebooks",
          "group": "navigation@2"
        },
        {
          "command": "serialTerminal.scriptView.revealNotebooks",
          "when": "view == serialport.scriptsNotebooks",
          "group": "navigation@4"
        },
        {
          "command": "serialTerminal.terminal.startSaveLog",
          "when": "view == terminal && serialTerminal.terminal.focus && !serialTerminal.terminal.recordingLog",
          "group": "navigation"
        },
        {
          "command": "serialTerminal.terminal.stopSaveLog",
          "when": "view == terminal && serialTerminal.terminal.focus && serialTerminal.terminal.recordingLog",
          "group": "navigation"
        },
        {
          "command": "serialTerminal.terminal.clear",
          "when": "view == terminal",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "serialTerminal.serialView.open",
          "when": "view == serialport.serialportView",
          "group": "inline"
        },
        {
          "command": "serialTerminal.treeItem.revealInExplorer",
          "when": "view == serialport.logs || view == serialport.scriptsNotebooks",
          "group": "navigation@1"
        },
        {
          "command": "serialTerminal.treeItem.deleteResource",
          "when": "view == serialport.logs || view == serialport.scriptsNotebooks",
          "group": "navigation@2"
        }
      ]
    },
    "commands": [
      {
        "command": "serialTerminal.terminal.startSaveLog",
        "icon": "$(save-as)",
        "title": "%commands.terminal.startSaveLog%"
      },
      {
        "command": "serialTerminal.terminal.stopSaveLog",
        "icon": "$(stop-circle)",
        "title": "%commands.terminal.stopSaveLog%"
      },
      {
        "command": "serialTerminal.terminal.clear",
        "icon": "$(clear-all)",
        "title": "%commands.terminal.clear%"
      },
      {
        "command": "serialTerminal.setting.SerialPort",
        "icon": "$(gear)",
        "title": "%commands.setting.SerialPort%"
      },
      {
        "command": "serialTerminal.setting.Log",
        "icon": "$(gear)",
        "title": "%commands.setting.Log%"
      },
      {
        "command": "serialTerminal.setting.Notebook",
        "icon": "$(gear)",
        "title": "%commands.setting.Notebook%"
      },
      {
        "icon": "$(arrow-right)",
        "command": "serialTerminal.treeItem.openOnEditor",
        "title": "%commands.treeItem.openOnEditor%"
      },
      {
        "command": "serialTerminal.treeItem.revealInExplorer",
        "icon": "$(file-directory)",
        "title": "%commands.treeItem.revealInExplorer%"
      },
      {
        "command": "serialTerminal.treeItem.deleteResource",
        "icon": "$(trash)",
        "title": "%commands.treeItem.deleteResource%"
      },
      {
        "command": "serialTerminal.serialView.open",
        "icon": "$(arrow-right)",
        "title": "%commands.serialView.open%"
      },
      {
        "command": "serialTerminal.serialView.refresh",
        "icon": "$(sync)",
        "title": "%commands.serialView.refresh%"
      },
      {
        "command": "serialTerminal.logView.openOnEditor",
        "title": "%commands.logView.openOnEditor%"
      },
      {
        "command": "serialTerminal.logView.revealLogs",
        "icon": "$(file-directory)",
        "title": "%commands.logView.revealLogs%"
      },
      {
        "command": "serialTerminal.scriptView.newNotebook",
        "icon": "$(new-file)",
        "title": "%commands.scriptView.newNotebook%"
      },
      {
        "command": "serialTerminal.scriptView.revealNotebooks",
        "icon": "$(file-directory)",
        "title": "%commands.scriptView.revealNotebooks%"
      }
    ],
    "configuration": {
      "title": "Serial Terminal",
      "properties": {
        "SerialTerminal.serialPort.configurations": {
          "title": "%setting.serialPort.configurations.title%",
          "type": "array",
          "default": [
            "115200n1",
            "9600n1",
            "19200n1",
            "38400n1",
            "76800n1",
            "153600n1",
            "460800n1",
            "921600n1",
            "2000000n1"
          ],
          "items": {
            "type": "string",
            "pattern": "^(\\d+)((n|e|o)([5678])?(1|1.5|2)?)?$"
          },
          "markdownDescription": "%setting.serialPort.configurations.description%"
        },
        "SerialTerminal.log.savePath": {
          "title": "%setting.log.savePath.title%",
          "type": "string",
          "markdownDescription": "%setting.log.savePath.description%"
        },
        "SerialTerminal.log.autoSave": {
          "title": "%setting.log.autoSave.title%",
          "type": "boolean",
          "default": false,
          "markdownDescription": "%setting.log.autoSave.description%"
        },
        "SerialTerminal.log.timestamp.enable": {
          "title": "%setting.log.timestamp.enable.title%",
          "type": "boolean",
          "default": false,
          "markdownDescription": "%setting.log.timestamp.enable.description%"
        },
        "SerialTerminal.log.timestamp.duration": {
          "title": "%setting.log.timestamp.duration.title%",
          "type": "number",
          "default": 20000000,
          "markdownDescription": "%setting.log.timestamp.duration.description%"
        },
        "SerialTerminal.notebook.savePath": {
          "title": "%setting.notebook.savePath.title%",
          "type": "string",
          "markdownDescription": "%setting.notebook.savePath.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.76.0",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "@vscode/l10n-dev": "^0.0.26",
    "@vscode/test-electron": "^2.3.0",
    "electron": "^25.0.1",
    "eslint": "^8.39.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.33",
    "@vscode/l10n": "^0.0.14",
    "colors": "^1.4.0",
    "serialport": "^11.0.0"
  }
}